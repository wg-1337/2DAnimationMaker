{
  "name": "@animation-maker/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Android 移动端 (Capacitor WebView)",
  "scripts": {
    "dev": "vite --config vite.mobile.config.ts",
    "build": "tsc && vite build --config vite.mobile.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@animation-maker/renderer": "workspace:*",
    "@animation-maker/shared": "workspace:*",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "hammerjs": "^2.0.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/hammerjs": "^2.0.45",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
